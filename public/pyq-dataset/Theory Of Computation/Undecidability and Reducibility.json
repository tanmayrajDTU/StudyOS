            "question": {
                "text": "Let A \\le m B  denotes that language A is mapping \nreducible (also known as many-to-one reducible) to \nlanguage B. Which one of the following is FALSE?",
                "images": [],
                "latex": [],
                "tables": []
            },
            "options": [
                {
                    "id": "A",
                    "text": "If  A \\le m B  and B is recursive then A is \nrecursive.",
                    "images": [],
                    "latex": [],
                    "tables": []
                },
                {
                    "id": "B",
                    "text": "If A \\le m B and A is undecidable then B is \nundecidable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                },
                {
                    "id": "C",
                    "text": "If A \\le m B and B is recursively enumerable then \nA is recursively enumerable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                },
                {
                    "id": "D",
                    "text": "If A \\le m B and B is not recursively enumerable \nthen A is not recursively enumerable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                }
            ],
            "correctAnswer": [
                "D"
            ],
            "solution": {
                "text": "Given A \\le m B \n• \nIf A \\le m recursive then, A will be recursive. \n• \nIf Undecidable \\le m B then, B must be \nUndecidable. \n• \nIf A \\le m RE then, A will be RE. \n• \nIf A \\le m NOT RE then, A may/may not be \nNOT RE. \nHence, option (d) is false statement in given data.",
                "images": [],
                "latex": [],
                "tables": []
            }
        }
