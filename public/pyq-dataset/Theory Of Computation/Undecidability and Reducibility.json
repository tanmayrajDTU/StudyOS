            "question": {
                "text": "For a Turing machine M, 〈M〉 denotes an encoding \nof M. Consider the following two languages. \n\nL1 = {〈M〉|M takes more than 2021 steps on all \ninputs}. \n\nL2 = {〈M〉|M takes more than 2021 steps on some \ninput}. \n\nWhich one of the following options is correct?",
                "images": [],
                "latex": [],
                "tables": []
            },
            "options": [
                {
                    "id": "A",
                    "text": "Both L1 and L2 are decidable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                },
                {
                    "id": "B",
                    "text": "L1 is decidable and  L2 is undecidable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                },
                {
                    "id": "C",
                    "text": "L1 is undecidable and  L2 is decidable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                },
                {
                    "id": "D",
                    "text": "Both  L1 and  L2 are undecidable.",
                    "images": [],
                    "latex": [],
                    "tables": []
                }
            ],
            "correctAnswer": [
                "A"
            ],
            "solution": {
                "text": "L1 = {〈M〉|M takes more than 2021 steps on all \ninputs} Decidable. \n\nVerify every string in length 0 to 2021.  \n\nL2 = {〈M〉|M takes more than 2021 steps on some \ninput}Decidable. \n\nVerify each string upto 2021 length. If any of these \nstrings takes more than 2021 steps, it is valid M.",
                "images": [],
                "latex": [],
                "tables": []
            }
        },
